# Home4U FB-Crawler — Environment

# Supabase Service-Role (für bulk_upsert_fb_listings RPC)
SUPABASE_URL=https://fhvkjjwwlqbkumpehjuz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Klassifikator + Extraktor, Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5  # optional override

# CDP-Attach
CDP_PORT=9222
CHROME_PROFILE_DIR=~/.home4u-fb-chrome

# State (lokales SQLite für seen-IDs)
STATE_DB_PATH=~/.home4u-fb-state/seen.sqlite

# Polling
POLL_INTERVAL_SECONDS=30

# Filter (kommagetrennt; leer = alle aus groups.json)
# CITIES=limassol,paphos
# GROUP_IDS=123456789,987654321

# Safety
DRY_RUN=0                     # 1 = klassifizieren+extrahieren, aber kein DB-Write
SKIP_LLM=0                    # 1 = Posts nur loggen, kein Anthropic-Call (Quota-Schutz)
