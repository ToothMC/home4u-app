# Home4U — Environment Variables
# Kopiere diese Datei nach .env.local und fülle die Werte.
# .env.local ist in .gitignore, Secrets bleiben lokal.

# ----- Anthropic (Sophie) -----
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Modell-IDs überschreiben (Defaults gesetzt in lib/anthropic.ts)
# ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
# ANTHROPIC_MODEL_OPUS=claude-opus-4-7
# ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----- OpenAI (Embeddings — Matching v0) -----
OPENAI_API_KEY=sk-...

# ----- WhatsApp BSP (360dialog, Phase 0 Outreach) -----
# DIALOG360_API_KEY=
# DIALOG360_PHONE_NUMBER_ID=

# ----- Telegram Bot (optional) -----
# TELEGRAM_BOT_TOKEN=

# ----- Resend (E-Mail) -----
# RESEND_API_KEY=
# RESEND_FROM="Home4U <hello@home4u.ai>"

# ----- Cron (Match-Notifications etc.) -----
# Secret zum Schutz von /api/cron/* gegen externe Aufrufe. Vercel Cron
# setzt automatisch x-vercel-cron-signature, dieser Secret ist nur für
# manuelle Trigger / lokale Tests. Min. 32 Zeichen.
# CRON_SECRET=

# Public App-URL für absolute Links in E-Mails
# NEXT_PUBLIC_APP_URL=https://home4u.ai

# ----- Bulk-Import (Makler) -----
# Secret zum Signieren des Preview-Tokens (HS256). Min. 32 Zeichen.
# Wenn nicht gesetzt, fällt der Importer auf SUPABASE_SERVICE_ROLE_KEY als Secret zurück.
# IMPORT_PREVIEW_SECRET=
