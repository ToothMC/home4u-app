SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Tuning
RATE_LIMIT_S=1.0
MAX_LISTINGS=0          # 0 = unlimited
MAX_RUNTIME_S=5400      # 90min Watchdog
STREAM_BATCH_SIZE=50
DEVELOPERS=             # leer = alle implementierten; sonst zB "aristo,pafilia"

# DRY_RUN=1            # nur loggen, kein DB-Write
# SKIP_PHASH=1         # pHash skippen
# FORCE_REFETCH=1      # auch bekannte Listings nochmal fetchen
